{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "cli"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "cryptodesk-agent",
      "args": {
        "image": "YOUR_DOCKERHUB_USERNAME/cryptodesk-agent:latest",
        "ports": ["3000:3000"],
        "gpu": true,
        "env": {
          "NODE_ENV": "production",
          "PORT": "3000",
          "OLLAMA_API_URL": "https://3yt39qx97wc9hqwwmylrphi4jsxrngjzxnjakkybnxbw.node.k8s.prd.nos.ci/api",
          "MODEL_NAME_AT_ENDPOINT": "qwen3:8b",
          "DATA_DIR": "/data/cryptodesk",
          "SERPER_API_KEY": "YOUR_SERPER_API_KEY"
        },
        "volumes": [
          {
            "name": "cryptodesk-data",
            "mountPath": "/data/cryptodesk"
          }
        ]
      }
    }
  ]
}
