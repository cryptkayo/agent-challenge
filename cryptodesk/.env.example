# ─── LLM Configuration ────────────────────────────────────────────────────────

# Option A: Nosana Hosted Endpoint (Recommended for deployment)
# Get your endpoint from the Nosana dashboard after deploying
OLLAMA_API_URL=https://3yt39qx97wc9hqwwmylrphi4jsxrngjzxnjakkybnxbw.node.k8s.prd.nos.ci/api
MODEL_NAME_AT_ENDPOINT=qwen3:8b

# Option B: Local Ollama for development
# OLLAMA_API_URL=http://127.0.0.1:11434/api
# MODEL_NAME_AT_ENDPOINT=qwen3:0.6b

# Option C: OpenAI (uncomment if using OpenAI)
# OPENAI_API_KEY=your-openai-key-here

# ─── Web Search (Optional but recommended for live research) ──────────────────
# Get a free key at serper.dev (2,500 free queries/month)
# Without this, the agent falls back to DuckDuckGo instant answers
SERPER_API_KEY=your-serper-key-here

# ─── App Configuration ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Data Storage ─────────────────────────────────────────────────────────────
# Path where watchlist/reminders are persisted inside the container
DATA_DIR=/data/cryptodesk

# ─── CopilotKit ───────────────────────────────────────────────────────────────
# Leave empty for self-hosted (uses local Mastra runtime)
COPILOTKIT_RUNTIME_URL=http://localhost:4111/api/copilotkit
